<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Vector icons drawn as path data. Kept as geometry rather than image assets so they stay
         crisp at any DPI, recolour with the theme, and add no files to deploy.
         All are authored on a 24x24 grid. -->

