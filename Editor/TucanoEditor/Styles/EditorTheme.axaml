<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shared look for the whole editor: one place to change the palette, and both windows stay
         consistent. Colours are a dark neutral base with a single amber accent. -->

    <Styles.Resources>
        <Color x:Key="AccentColor">#FFC107</Color>
        <Color x:Key="AccentDimColor">#FFB300</Color>

        <SolidColorBrush x:Key="Accent" Color="#FFC107" />
        <SolidColorBrush x:Key="AccentDim" Color="#FFB300" />
        <SolidColorBrush x:Key="AccentFaint" Color="#3A2E08" />

        <SolidColorBrush x:Key="Bg0" Color="#0B0B0D" />   <!-- window -->
        <SolidColorBrush x:Key="Bg1" Color="#121215" />   <!-- panels -->
        <SolidColorBrush x:Key="Bg2" Color="#17171B" />   <!-- headers, toolbar -->
        <SolidColorBrush x:Key="Bg3" Color="#1E1E23" />   <!-- cards, inputs -->
        <SolidColorBrush x:Key="Bg4" Color="#26262C" />   <!-- hover -->

        <SolidColorBrush x:Key="Line" Color="#2A2A31" />
        <SolidColorBrush x:Key="LineSoft" Color="#202027" />

        <SolidColorBrush x:Key="Text0" Color="#E8E8EC" />  <!-- primary -->
        <SolidColorBrush x:Key="Text1" Color="#A9A9B4" />  <!-- secondary -->
        <SolidColorBrush x:Key="Text2" Color="#6C6C78" />  <!-- muted / labels -->

        <SolidColorBrush x:Key="AxisX" Color="#E5534B" />
        <SolidColorBrush x:Key="AxisY" Color="#5FBF66" />
        <SolidColorBrush x:Key="AxisZ" Color="#4C8DF6" />

        <SolidColorBrush x:Key="Ok" Color="#5FBF66" />
        <SolidColorBrush x:Key="Warn" Color="#FFC107" />
        <SolidColorBrush x:Key="Danger" Color="#E5534B" />
    </Styles.Resources>

    <!-- ── Buttons ─────────────────────────────────── -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource Bg3}" />
        <Setter Property="Foreground" Value="{StaticResource Text0}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource Bg4}" />
        <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentFaint}" />
    </Style>
    <Style Selector="Button:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource Bg1}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource Text2}" />
    </Style>

    <!-- Toolbar buttons: compact, icon-ish -->
    <Style Selector="Button.tool">
        <Setter Property="Padding" Value="9,3" />
        <Setter Property="Height" Value="26" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.transport">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="26" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{StaticResource AccentFaint}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentDim}" />
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ── Menu ────────────────────────────────────── -->
    <Style Selector="Menu">
        <Setter Property="Background" Value="{StaticResource Bg2}" />
    </Style>
    <Style Selector="Menu > MenuItem">
        <Setter Property="Foreground" Value="{StaticResource Text0}" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ── Text ────────────────────────────────────── -->
    <Style Selector="TextBlock.h">           <!-- panel header -->
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="LetterSpacing" Value="1.4" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.section">     <!-- card title -->
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AccentDim}" />
        <Setter Property="LetterSpacing" Value="1.2" />
        <Setter Property="Margin" Value="0,0,0,2" />
    </Style>
    <Style Selector="TextBlock.label">       <!-- field label -->
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Foreground" Value="{StaticResource Text2}" />
        <Setter Property="Margin" Value="0,6,0,1" />
    </Style>
    <Style Selector="TextBlock.dim">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource Text2}" />
    </Style>
    <Style Selector="TextBlock.axis">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Width" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- ── Cards ───────────────────────────────────── -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource Bg3}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{StaticResource Bg1}" />
    </Style>
    <Style Selector="Border.header">
        <Setter Property="Background" Value="{StaticResource Bg2}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Height" Value="30" />
    </Style>

    <!-- ── Numeric fields ──────────────────────────── -->
    <!-- The spinner buttons ate the whole control at the widths a transform row allows, leaving no
         visible number. Type-in fields are what a transform row actually needs. -->
    <Style Selector="NumericUpDown">
        <Setter Property="ShowButtonSpinner" Value="False" />
        <Setter Property="Background" Value="{StaticResource Bg1}" />
        <Setter Property="Foreground" Value="{StaticResource Text0}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="NumericUpDown:pointerover /template/ TextBox">
        <Setter Property="BorderBrush" Value="{StaticResource AccentDim}" />
    </Style>
    <Style Selector="NumericUpDown /template/ TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Text0}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource Bg1}" />
        <Setter Property="Foreground" Value="{StaticResource Text0}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Padding" Value="6,3" />
    </Style>

    <!-- ── Checkbox / combo / slider ───────────────── -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Text1}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="6,0,0,0" />
    </Style>
    <Style Selector="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource Text1}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="6,0,0,0" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource Bg1}" />
        <Setter Property="Foreground" Value="{StaticResource Text0}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <Style Selector="Slider">
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="Margin" Value="0,-2" />
    </Style>
    <Style Selector="Slider /template/ Track">
        <Setter Property="Height" Value="3" />
    </Style>

    <!-- ── Lists ───────────────────────────────────── -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Text1}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource Bg3}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentFaint}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource Accent}" />
    </Style>

    <!-- ── Tabs ────────────────────────────────────── -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="{StaticResource Bg1}" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="TabItem">
        <Setter Property="Foreground" Value="{StaticResource Text2}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Padding" Value="14,5" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Background" Value="{StaticResource Bg2}" />
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
    </Style>
    <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
        <Setter Property="Background" Value="{StaticResource Accent}" />
    </Style>

    <!-- ── Splitters: the visible seam between docked panels ── -->
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="{StaticResource LineSoft}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="GridSplitter:pointerover">
        <Setter Property="Background" Value="{StaticResource AccentDim}" />
    </Style>

    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- ── Icons ───────────────────────────────────── -->
    <!-- Stroked line art: no fill, rounded joins, so one geometry reads well at any size. -->
    <Style Selector="Path.ico">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Stroke" Value="{StaticResource Text1}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeJoin" Value="Round" />
        <Setter Property="StrokeLineCap" Value="Round" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Toolbar group separator -->
    <Style Selector="Border.sep">
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Background" Value="{StaticResource Line}" />
        <Setter Property="Margin" Value="8,0" />
    </Style>

    <!-- ── Expander: the component headers in the inspector ── -->
    <Style Selector="Expander">
        <Setter Property="Background" Value="{StaticResource Bg3}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton:pointerover">
        <Setter Property="Background" Value="{StaticResource Bg4}" />
    </Style>

    <!-- ── Trees ───────────────────────────────────── -->
    <Style Selector="TreeView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TreeViewItem">
        <Setter Property="Foreground" Value="{StaticResource Text1}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="IsExpanded" Value="True" />
    </Style>
    <Style Selector="TreeViewItem /template/ Border#PART_LayoutRoot">
        <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{StaticResource AccentFaint}" />
    </Style>
    <Style Selector="TreeViewItem:selected">
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
    </Style>

    <!-- Content-browser tiles: the whole card highlights, not just the label -->
    <Style Selector="ListBox.tiles ListBoxItem">
        <Setter Property="Padding" Value="4" />
        <Setter Property="Margin" Value="2" />
    </Style>

    <!-- Eye toggle in the outliner: invisible until hovered so rows stay quiet -->
    <Style Selector="Button.eye">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Opacity" Value="0.45" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.eye:pointerover">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.eye:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <!-- Row highlighted while a drag hovers over it as a drop target -->
    <Style Selector="TreeViewItem.droptarget /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{StaticResource AccentFaint}" />
        <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Filter chips: a toggle that reads as on/off at a glance -->
    <Style Selector="ToggleButton.chip">
        <Setter Property="Background" Value="{StaticResource Bg1}" />
        <Setter Property="Foreground" Value="{StaticResource Text2}" />
        <Setter Property="BorderBrush" Value="{StaticResource Line}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Padding" Value="11,2" />
        <Setter Property="Height" Value="24" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton.chip:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentFaint}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentDim}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource Accent}" />
    </Style>
    <Style Selector="ToggleButton.chip:pointerover /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
    </Style>
</Styles>
