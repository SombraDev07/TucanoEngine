#pragma once

#define B3D_FRAMEWORK_VERSION_MAJOR @B3D_FRAMEWORK_VERSION_MAJOR@
#define B3D_FRAMEWORK_VERSION_MINOR @B3D_FRAMEWORK_VERSION_MINOR@
#define B3D_FRAMEWORK_VERSION_PATCH @B3D_FRAMEWORK_VERSION_PATCH@
#define B3D_FRAMEWORK_CURRENT_RELEASE_YEAR @B3D_FRAMEWORK_CURRENT_RELEASE_YEAR@

// NOLINTBEGIN
#ifndef _STR
#define _STR(m_x) #m_x
/**
 * This macro converts the preprocessor defined macro into textual form.
 * @note Currently used internally for binary information in Win32 resource files
 */
#define _MKSTR(m_x) _STR(m_x)
#endif
// NOLINTEND

#define B3D_FRAMEWORK_VERSION_STRING _MKSTR(B3D_FRAMEWORK_VERSION_MAJOR) "." _MKSTR(B3D_FRAMEWORK_VERSION_MINOR) "." _MKSTR(B3D_FRAMEWORK_VERSION_PATCH) ".0"

#define B3D_IS_ENGINE @B3D_IS_ENGINE@
#define B3D_WITH_EDITOR @B3D_IS_ENGINE@ // For now always enable this, but later set up a non-editor build for standalone game
#cmakedefine01 B3D_MONO_AOT

#define B3D_PLATFORM_NAME @B3D_PLATFORM@
#define B3D_PLATFORM B3D_PLATFORM_ID_@B3D_PLATFORM_UPPER@

// Build type ID constants
#define B3D_BUILD_TYPE_SHIPPING_ID @B3D_BUILD_TYPE_SHIPPING_ID@
#define B3D_BUILD_TYPE_DEVELOPMENT_ID @B3D_BUILD_TYPE_DEVELOPMENT_ID@
#define B3D_BUILD_TYPE_PROFILING_ID @B3D_BUILD_TYPE_PROFILING_ID@

// Current build type
#define B3D_BUILD_TYPE @B3D_BUILD_TYPE_ID@

// Boolean convenience macros
#define B3D_BUILD_TYPE_SHIPPING (B3D_BUILD_TYPE == B3D_BUILD_TYPE_SHIPPING_ID)
#define B3D_BUILD_TYPE_DEVELOPMENT (B3D_BUILD_TYPE == B3D_BUILD_TYPE_DEVELOPMENT_ID)
#define B3D_BUILD_TYPE_PROFILING (B3D_BUILD_TYPE == B3D_BUILD_TYPE_PROFILING_ID)

// Testing support
#cmakedefine01 B3D_ENABLE_TESTS

// Monolithic build: non-importer plugins are statically linked into bsf
#cmakedefine01 B3D_MONOLITHIC_BUILD
