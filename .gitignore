# Build & IDE
/build/
/out/
/.vs/
/.idea/
/cache/
CMakeUserPresets.json
*.user
*.pdb
*.ilk
*.suo
*.VC.db

# Captures / local screenshots
/captures/*.png
!/captures/.gitkeep

# Third-party engine trees (reference only — never ship)
/DagorEngine/
/-CRYENGINE-Community-Edition--main/
/-CRYENGINE*/
/CRYENGINE*/

